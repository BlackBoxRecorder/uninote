# Authentication
AUTH_SECRET_KEY=your-secret-key-here
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
JWT_EXPIRY=7d

# Database
DATABASE_PATH=./data/ynote.db

# Tencent COS (optional, defaults to local storage if not configured)
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou

# Feishu/Lark (optional)
LARK_APP_ID=
LARK_APP_SECRET=
LARK_ENCRYPT_KEY=
LARK_VERIFICATION_TOKEN=
# 如果留空，则允许所有用户访问
LARK_ALLOWED_USER_IDS=
LARK_FOLDER_TOKEN=
# Event mode: "webhook" (default) or "websocket"
# webhook: receive events via HTTP webhook (requires public URL)
# websocket: receive events via long connection (no public URL needed)
LARK_EVENT_MODE=webhook
